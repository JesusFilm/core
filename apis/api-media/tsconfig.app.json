{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "outDir": "../../dist/out-tsc",
    "module": "commonjs",
    "types": [
      "node",
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts"
    ],
    "emitDecoratorMetadata": true,
    "target": "es2021"
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "vitest.config.mts",
    "**/__mocks/*.ts",
    "**/test/*.ts"
  ],
  "include": ["**/*.ts"]
}
