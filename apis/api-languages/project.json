{
  "name": "api-languages",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apis/api-languages/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": [
        "{options.outputPath}"
      ],
      "defaultConfiguration": "development",
      "options": {
        "outputPath": "dist/apps/api-languages",
        "main": "apis/api-languages/src/index.ts",
        "tsConfig": "apis/api-languages/tsconfig.app.json",
        "compiler": "tsc",
        "target": "node",
        "webpackConfig": "apis/api-languages/webpack.config.js"
      },
      "configurations": {
        "production": {
          "generatePackageJson": true,
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx _serve api-languages | pnpm exec pino-pretty --config .pino-prettyrc.js"
      }
    },
    "_serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api-languages:build",
        "inspect": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": [
        "{options.outputFile}"
      ],
      "options": {
        "cache": true,
        "cacheLocation": ".cache/api-languages/eslint",
        "cacheStrategy": "content"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": [
        "{workspaceRoot}/coverage/apis/api-languages"
      ],
      "options": {
        "configFile": "apis/api-languages/vitest.config.mts"
      }
    },
    "generate-graphql": {
      "executor": "nx:run-commands",
      "options": {
        "command": "GENERATE_SCHEMA=true pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json -r tsconfig-paths/register apis/api-languages/src/schema/index.ts"
      }
    },
    "subgraph-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec hive schema:check apis/api-languages/schema.graphql --registry.accessToken $HIVE_TOKEN --github --service api-languages"
      }
    },
    "fetch-secrets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "DOPPLER_TOKEN=$DOPPLER_API_LANGUAGES_TOKEN doppler secrets download --no-file --format=env-no-quotes --project api-languages > apis/api-languages/.env"
      }
    },
    "fetch-secrets-stage": {
      "executor": "nx:run-commands",
      "options": {
        "command": "DOPPLER_CONFIG=stg DOPPLER_TOKEN=$DOPPLER_API_LANGUAGES_TOKEN doppler secrets download --no-file --format=env-no-quotes --project api-languages > apis/api-languages/.env.stage"
      }
    },
    "fetch-secrets-prod": {
      "executor": "nx:run-commands",
      "options": {
        "command": "DOPPLER_CONFIG=prd DOPPLER_TOKEN=$DOPPLER_API_LANGUAGES_TOKEN doppler secrets download --no-file --format=env-no-quotes --project api-languages > apis/api-languages/.env.prod"
      }
    },
    "fetch-secrets-envs": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "DOPPLER_CONFIG=stg DOPPLER_TOKEN=$DOPPLER_API_LANGUAGES_TOKEN doppler secrets download --no-file --format=env-no-quotes --project api-languages > apis/api-languages/.env.stage",
          "DOPPLER_CONFIG=prd DOPPLER_TOKEN=$DOPPLER_API_LANGUAGES_TOKEN doppler secrets download --no-file --format=env-no-quotes --project api-languages > apis/api-languages/.env.prod"
        ],
        "parallel": false
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsc -b apis/api-languages/tsconfig.json"
      }
    },
    "codecov": {
      "executor": "nx:run-commands",
      "options": {
        "command": "codecov -f coverage/apis/api-languages/cobertura-coverage.xml -F apps.api-languages"
      }
    },
    "data-export": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx apis/api-languages/src/workers/cli.ts data-export"
      }
    },
    "data-import": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx apis/api-languages/src/scripts/data-import.ts"
      }
    },
    "audit-arclight-cloudfront-refs": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json apis/api-languages/src/scripts/audit-arclight-cloudfront-refs.ts"
      }
    },
    "wess-languages-import": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json apis/api-languages/src/scripts/wess-languages-import.ts"
      }
    },
    "wess-countries-import": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json apis/api-languages/src/scripts/wess-countries-import.ts"
      }
    },
    "wess-country-languages-import": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json apis/api-languages/src/scripts/wess-country-languages-import.ts"
      }
    },
    "_wess-inspect": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json tmp/wess-inspect.ts"
      }
    },
    "_wess-find-unmatched-geo": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json tmp/wess-find-unmatched-geo.ts"
      }
    },
    "_wess-check-155-dups": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json tmp/wess-check-155-dups.ts"
      }
    },
    "migrate-country-flags-to-r2": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-languages/tsconfig.app.json apis/api-languages/src/scripts/migrate-country-flags-to-r2.ts"
      }
    }
  }
}
