{
  "name": "api-journeys",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apis/api-journeys/src",
  "projectType": "application",
  "tags": [],
  "targets": {
    "build": {
      "executor": "@nx/webpack:webpack",
      "outputs": ["{options.outputPath}"],
      "defaultConfiguration": "development",
      "options": {
        "outputPath": "dist/apps/api-journeys",
        "main": "apis/api-journeys/src/index.ts",
        "tsConfig": "apis/api-journeys/tsconfig.app.json",
        "compiler": "tsc",
        "target": "node",
        "webpackConfig": "apis/api-journeys/webpack.config.js"
      },
      "configurations": {
        "production": {
          "generatePackageJson": true,
          "optimization": true,
          "extractLicenses": true,
          "inspect": false
        }
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "options": {
        "command": "nx _serve api-journeys | pnpm exec pino-pretty --config .pino-prettyrc.js"
      }
    },
    "_serve": {
      "executor": "@nx/js:node",
      "options": {
        "buildTarget": "api-journeys:build",
        "inspect": false
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "cache": true,
        "cacheLocation": ".cache/api-journeys/eslint",
        "cacheStrategy": "content"
      }
    },
    "test": {
      "executor": "@nx/vitest:test",
      "outputs": ["{workspaceRoot}/coverage/apis/api-journeys"],
      "options": {
        "configFile": "apis/api-journeys/vitest.config.mts"
      }
    },
    "generate-graphql": {
      "executor": "nx:run-commands",
      "options": {
        "command": "GENERATE_SCHEMA=true pnpm exec tsx --tsconfig apis/api-journeys/tsconfig.app.json -r tsconfig-paths/register apis/api-journeys/src/schema/index.ts"
      }
    },
    "subgraph-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec hive schema:check apis/api-journeys/schema.graphql --registry.accessToken $HIVE_TOKEN --github --service api-journeys-modern"
      }
    },
    "fetch-secrets": {
      "executor": "nx:run-commands",
      "options": {
        "command": "DOPPLER_TOKEN=$DOPPLER_API_JOURNEYS_TOKEN doppler secrets download --no-file --format=env-no-quotes --project api-journeys > apis/api-journeys/.env"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc7 -p apis/api-journeys/tsconfig.ts7.json"
      }
    },
    "codecov": {
      "executor": "nx:run-commands",
      "options": {
        "command": "codecov -f coverage/apis/api-journeys/cobertura-coverage.xml -F apps.api-journeys"
      }
    },
    "email": {
      "executor": "nx:run-commands",
      "options": {
        "parallel": false,
        "commands": [
          "if lsof -Pi :4601 -sTCP:LISTEN -t>/dev/null; then\nkill -9 $(lsof -Pi :4601 -sTCP:LISTEN -t)\nfi",
          "email dev --dir apis/api-journeys/src/emails/templates --port 4601"
        ]
      }
    },
    "update-shortlinks": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-journeys/tsconfig.app.json apis/api-journeys/src/workers/cli.ts shortlink-updater"
      }
    },
    "playwright-cleanup": {
      "executor": "nx:run-commands",
      "dependsOn": ["prisma-generate-ci"],
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-journeys/tsconfig.app.json -r tsconfig-paths/register apis/api-journeys/src/workers/cli.ts e2e-cleanup"
      }
    },
    "fix-cross-team-visitors": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm exec tsx --tsconfig apis/api-journeys/tsconfig.app.json -r tsconfig-paths/register apis/api-journeys/src/scripts/fix-cross-team-visitors.ts"
      }
    }
  }
}
