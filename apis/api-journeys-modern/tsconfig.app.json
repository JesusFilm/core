{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "strict": true,
    "types": [
      "node",
      "@nx/react/typings/cssmodule.d.ts",
      "@nx/react/typings/image.d.ts"
    ],
    "target": "es2021"
  },
  "exclude": [
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "vitest.config.mts",
    "test/**/*.ts"
  ],
  "include": ["**/*.ts", "**/*.tsx"]
}
