{
  "name": "video-importer",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/video-importer/src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": ["tsc -p apps/video-importer/tsconfig.json"],
        "parallel": false
      }
    },
    "run": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --import tsx apps/video-importer/src/video-importer.ts --folder apps/video-importer/test-videos --dry-run"
      }
    },
    "package": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cd apps/video-importer && ./build-scripts/build-cross-platform.sh",
          "mkdir -p dist/apps/video-importer-executable && cp -f apps/video-importer/README.md dist/apps/video-importer-executable/README.md"
        ],
        "parallel": false
      }
    },
    "compile": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cd apps/video-importer && ./build-scripts/build-cross-platform.sh",
          "mkdir -p dist/apps/video-importer-executable && cp -f apps/video-importer/README.md dist/apps/video-importer-executable/README.md"
        ],
        "parallel": false
      }
    },
    "fetch-secrets": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          {
            "command": "DOPPLER_TOKEN=$DOPPLER_VIDEO_IMPORTER_TOKEN doppler secrets download --no-file --format=env-no-quotes --project video-importer > apps/video-importer/.env"
          }
        ]
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "options": {
        "command": "node --experimental-test-module-mocks --import tsx --test apps/video-importer/src/**/*.spec.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "outputs": ["{options.outputFile}"],
      "options": {
        "cache": true,
        "cacheLocation": ".cache/video-importer/eslint",
        "cacheStrategy": "content"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "command": "pnpm tsc7 -p apps/video-importer/tsconfig.ts7.json"
      }
    }
  },
  "tags": []
}
