{
  "extends": [
    "plugin:@nx/react",
    "../../.eslintrc.json",
    "@react-native-community"
  ],
  "ignorePatterns": ["!**/*", ".expo", "web-build", "cache", "dist"],
  "overrides": [
    {
      "files": ["*.ts", "*.tsx", "*.js", "*.jsx"],
      "rules": {}
    },
    {
      "files": ["*.ts", "*.tsx"],
      "parserOptions": {
        "project": ["apps/disciple/tsconfig.*?.json"]
      },
      "rules": {}
    },
    {
      "files": ["*.js", "*.jsx"],
      "rules": {}
    }
  ]
}
