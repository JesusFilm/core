{
  "name": "arclight",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "apps/arclight",
  "projectType": "application",
  "tags": ["doppler_config:stg_dev"],
  "targets": {
    "build": {
      "executor": "nx:run-commands",
      "options": {
        "commands": [
          "cp -r libs/locales apps/arclight/public",
          "nx _build arclight"
        ],
        "parallel": false
      },
      "configurations": {
        "production": {
          "commands": [
            "cp -r libs/locales apps/arclight/public",
            "CI=true nx _build arclight --prod"
          ]
        }
      }
    },
    "_build": {
      "executor": "nx:run-commands",
      "outputs": ["{projectRoot}/.next"],
      "options": {
        "cwd": "apps/arclight",
        "command": "npx next build"
      },
      "configurations": {
        "production": {
          "command": "CI=true npx next build"
        }
      }
    },
    "deploy": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/arclight",
        "commands": [
          "VERCEL_PROJECT_ID=$ARCLIGHT_VERCEL_PROJECT_ID npx vercel pull --environment=preview --token=$VERCEL_TOKEN",
          "echo \"VERCEL_ENV=\\\"$NEXT_PUBLIC_VERCEL_ENV\\\"\" >> .vercel/.env.preview.local",
          "echo \"VERCEL_GIT_COMMIT_SHA=\\\"$NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA\\\"\" >> .vercel/.env.preview.local",
          "npx vercel build",
          "VERCEL_PROJECT_ID=$ARCLIGHT_VERCEL_PROJECT_ID npx vercel deploy --prebuilt --token=$VERCEL_TOKEN --archive=tgz > .vercel-url"
        ],
        "parallel": false
      },
      "configurations": {
        "production": {
          "cwd": "apps/arclight",
          "commands": [
            "VERCEL_PROJECT_ID=$ARCLIGHT_VERCEL_PROJECT_ID npx vercel pull --environment=production --token=$VERCEL_TOKEN",
            "echo \"VERCEL_ENV=\\\"$NEXT_PUBLIC_VERCEL_ENV\\\"\" >> .vercel/.env.production.local",
            "echo \"VERCEL_GIT_COMMIT_SHA=\\\"$NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA\\\"\" >> .vercel/.env.production.local",
            "npx vercel build --prod",
            "VERCEL_PROJECT_ID=$ARCLIGHT_VERCEL_PROJECT_ID npx vercel deploy --prebuilt --prod --token=$VERCEL_TOKEN --archive=tgz > .vercel-url"
          ]
        }
      }
    },
    "upload-sourcemaps": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/arclight",
        "commands": [
          "npx @datadog/datadog-ci sourcemaps upload .next/static --service=arclight --release-version=$GIT_COMMIT_SHA --minified-path-prefix=/_next/static/"
        ],
        "parallel": false
      }
    },
    "vercel-alias": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/arclight",
        "commands": [
          "npx vercel alias set $(cat .vercel-url) arclight-$PR_NUMBER-jesusfilm.vercel.app --token=$VERCEL_TOKEN --scope=jesusfilm",
          "echo \"https://arclight-$PR_NUMBER-jesusfilm.vercel.app\" > .vercel-url"
        ],
        "parallel": false
      }
    },
    "serve": {
      "executor": "nx:run-commands",
      "defaultConfiguration": "development",
      "options": {
        "cwd": "apps/arclight",
        "command": "npx next dev --port 4600"
      },
      "configurations": {
        "development": {
          "command": "npx next dev --port 4600"
        },
        "production": {
          "command": "npx next start --port 4600"
        }
      }
    },
    "export": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/arclight",
        "command": "npx next export"
      }
    },
    "test": {
      "executor": "nx:run-commands",
      "outputs": ["{workspaceRoot}/coverage/{projectRoot}"],
      "options": {
        "cwd": "apps/arclight",
        "command": "npx jest --config=jest.config.ts"
      }
    },
    "lint": {
      "executor": "nx:run-commands",
      "outputs": ["{options.outputFile}"],
      "options": {
        "cwd": "apps/arclight",
        "command": "npx eslint . --cache --cache-location=../../.cache/arclight/eslint"
      }
    },
    "type-check": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/arclight",
        "command": "npx tsc --noEmit"
      }
    },
    "fetch-secrets": {
      "executor": "nx:run-commands",
      "options": {
        "cwd": "apps/arclight",
        "commands": [
          {
            "command": "DOPPLER_TOKEN=$DOPPLER_ARCLIGHT_TOKEN doppler secrets download --no-file --format=env-no-quotes --project arclight > .env"
          }
        ]
      }
    },
    "extract-translations": {
      "executor": "nx:run-commands",
      "options": {
        "commands": []
      }
    }
  }
}
