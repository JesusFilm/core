{
  "permissions": {
    "deny": [
      "Read(**/.env*)",
      "Read(**/.env.*)",
      "Bash(docker run*-v /*)",
      "Bash(docker run*--privileged*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/compound-reminder.sh",
            "if": "Bash(git push*)",
            "statusMessage": "Checking for compound docs..."
          }
        ]
      }
    ]
  }
}
