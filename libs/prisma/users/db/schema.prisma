// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../src/__generated__/client"
}

datasource db {
  provider = "postgresql"
}

generator pothos {
  provider     = "prisma-pothos-types"
  clientOutput = "./client"
  output       = "../src/__generated__/pothos-types.ts"
}

model User {
  id            String   @id @default(uuid())
  userId        String   @unique
  firstName     String
  lastName      String?
  email         String?  @unique
  imageUrl      String?
  createdAt     DateTime @default(now())
  superAdmin    Boolean  @default(false)
  emailVerified Boolean  @default(true)
}

model UserDeleteAuditLog {
  id                      String   @id @default(uuid())
  deletedUserId           String
  deletedUserFirebaseUid  String?
  callerUserId            String
  callerEmail             String?
  deletedJourneyIds       String[]
  deletedTeamIds          String[]
  deletedUserJourneyIds   String[]
  deletedUserTeamIds      String[]
  success                 Boolean  @default(false)
  errorMessage            String?
  createdAt               DateTime @default(now())

  @@index(deletedUserId)
  @@index(callerUserId)
  @@index(createdAt)
}
